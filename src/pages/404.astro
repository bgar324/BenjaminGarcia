---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" canonicalPath="/404">
  <main class="flex min-h-screen items-center justify-center bg-white px-6 text-black">
    <div class="flex flex-col items-center gap-4 text-center sm:flex-row sm:gap-6 sm:text-left">
      <p class="text-2xl font-semibold sm:text-3xl">404</p>
      <div class="h-px w-12 bg-black sm:h-14 sm:w-px" aria-hidden="true"></div>
      <h1 class="text-sm font-medium sm:text-base">
        This page could not be found.
      </h1>
    </div>
  </main>
</BaseLayout>
