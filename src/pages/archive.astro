---
import { absoluteUrl, archiveProjects, siteConfig } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const archiveDescription =
  "A broader archive of product, AI, and web engineering work spanning Astro, React, TypeScript, Python, and Vercel deployments.";

const archiveStructuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${siteConfig.name} Project Archive`,
  description: archiveDescription,
  url: absoluteUrl("/archive"),
  isPartOf: {
    "@type": "WebSite",
    name: siteConfig.name,
    url: siteConfig.url,
  },
  mainEntity: {
    "@type": "ItemList",
    itemListOrder: "https://schema.org/ItemListOrderDescending",
    numberOfItems: archiveProjects.length,
    itemListElement: archiveProjects.map((project, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "CreativeWork",
        name: project.title,
        dateCreated: String(project.year),
        url: project.websiteLink ?? project.githubLink ?? absoluteUrl("/archive"),
        keywords: project.builtWith.join(", "),
      },
    })),
  },
};
---

<BaseLayout title="Project Archive" description={archiveDescription} canonicalPath="/archive">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(archiveStructuredData)} />

  <main class="archive-page">
    <header class="archive-header">
      <a class="text-arrow-link" href="/">Benjamin Garcia</a>
      <h1>Things I have built.</h1>
    </header>

    <ol class="archive-list">
      {archiveProjects.map((project) => (
        <li class="archive-row">
          <p class="archive-year">{project.year}</p>
          <div class="archive-project">
            <h2>
              {project.websiteLink ? (
                <a href={project.websiteLink} target="_blank" rel="noopener noreferrer">{project.title}</a>
              ) : (
                project.title
              )}
            </h2>
            <p>{project.builtWith.join(" · ")}</p>
          </div>
          <div class="archive-links">
            {project.githubLink && <a href={project.githubLink} target="_blank" rel="noopener noreferrer">GitHub</a>}
          </div>
        </li>
      ))}
    </ol>

    <footer class="site-footer">
      <p>Benjamin Garcia · {new Date().getFullYear()}</p>
    </footer>
  </main>
</BaseLayout>
