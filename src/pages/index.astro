---
import {
  experiences,
  resumeHref,
  selectedProjects,
  siteConfig,
  socialLinks,
} from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = selectedProjects.map((project) => ({
  ...project,
  techLine: project.featuredTags.join(" · "),
}));

const featuredExperience = [
  {
    ...experiences[0],
    summary: "Building core services for email and meeting agents across Lindy's work-assistant platform.",
  },
  {
    ...experiences[1],
    summary: "Researching multi-agent systems for scientific hypothesis generation at UCLA's HCI lab.",
  },
  {
    ...experiences[2],
    summary: "Built the first client dashboard for AI-powered crop insights and early product adoption.",
  },
  {
    ...experiences[3],
    summary: "Prototyped agentic AI pipelines for nonprofit event analysis and helped shape early AI adoption strategy.",
  },
  {
    ...experiences[4],
    summary: "Designed secure, low-latency interfaces for enterprise data and credential workflows.",
  },
];

const email = socialLinks.find((link) => link.label === "Email")!;
const linkedin = socialLinks.find((link) => link.label === "LinkedIn")!;
const sourceHref = "https://github.com/bgar324/BenjaminGarcia-v4";

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: siteConfig.name,
    url: siteConfig.url,
    email: siteConfig.email,
    jobTitle: siteConfig.jobTitle,
    description: siteConfig.description,
    knowsAbout: siteConfig.keywords,
    sameAs: siteConfig.sameAs,
    homeLocation: {
      "@type": "Place",
      name: siteConfig.location,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.name,
    url: siteConfig.url,
    description: siteConfig.description,
    inLanguage: "en-US",
    author: {
      "@type": "Person",
      name: siteConfig.name,
    },
  },
];
---

<BaseLayout canonicalPath="/">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(homeStructuredData)} />

  <main class="site-page" id="top">
    <section class="intro" aria-labelledby="home-heading">
      <h2 class="intro-greeting reveal" style="--delay: 0ms">Hi, I'm Benjamin</h2>
      <h1 id="home-heading" class="reveal" style="--delay: 1500ms">I build software that turns complex systems into simple experiences.</h1>
      <p class="intro-copy reveal" style="--delay: 1950ms">
        Currently building infrastructure for agents at <a href="https://www.lindy.ai" target="_blank" rel="noopener noreferrer">Lindy</a> and studying Computer Science at <a href="https://ucla.edu" target="_blank" rel="noopener noreferrer">UCLA</a>.
      </p>
    </section>

    <section class="content-section reveal" style="--delay: 2300ms" id="experience" aria-labelledby="experience-heading">
      <div class="section-heading">
        <h2 id="experience-heading">Experience</h2>
        <a class="section-link" href={resumeHref} target="_blank" rel="noopener noreferrer">Full résumé</a>
      </div>

      <ol class="experience-list">
        {featuredExperience.map((item) => (
          <li class="experience-row">
            <div class="experience-heading">
              <h3><a href={item.imageLink} target="_blank" rel="noopener noreferrer">{item.position}</a></h3>
              <p>{item.startDate} — {item.endDate}</p>
            </div>
            <p class="experience-role">{item.role}</p>
            <p class="experience-summary">{item.summary}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="content-section" id="work" aria-labelledby="work-heading">
      <div class="section-heading reveal" style="--delay: 2650ms">
        <h2 id="work-heading">Selected work</h2>
        <a class="section-link" href="/archive">All projects</a>
      </div>

      <div class="project-list">
        {projects.map((project, index) => (
          <article class="project reveal" style={`--delay: ${3000 + index * 250}ms`}>
            <div class="project-heading">
              <h3><a href={project.link} target="_blank" rel="noopener noreferrer">{project.title}</a></h3>
              <div class="project-links">
                <a href={project.githubLink} target="_blank" rel="noopener noreferrer">Source</a>
              </div>
            </div>
            <p>{project.summary}</p>
            <p class="project-tech">{project.techLine}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section reveal" style="--delay: 3850ms" id="about" aria-labelledby="about-heading">
      <div class="section-heading">
        <h2 id="about-heading">About</h2>
      </div>
      <div class="about-copy">
        <p>I am a product-minded software engineer who cares about making software fast, accessible, and obvious to use.</p>
        <p>The best way to reach me is on <a href={linkedin.href} target="_blank" rel="noopener noreferrer">LinkedIn</a>, or by <a href={email.href}>email</a>.</p>
        <p>If you like this site, you can find the source on <a href={sourceHref} target="_blank" rel="noopener noreferrer">GitHub</a>.</p>
      </div>
    </section>

    <footer class="site-footer reveal" style="--delay: 4200ms">
      <p>Benjamin Garcia · {new Date().getFullYear()}</p>
    </footer>
  </main>
</BaseLayout>
