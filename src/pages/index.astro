---
import { getImage } from "astro:assets";
import Icon from "../components/Icon.astro";
import Dropdown from "../components/Dropdown.astro";
import FooterLink from "../components/FooterLink.astro";
import RippleLink from "../components/RippleLink.astro";
import profilePhoto from "../assets/profile/me.jpg";
import gitproofPreview from "../assets/projects/gitproof.png";
import logitPreview from "../assets/projects/logit.png";
import homIcon from "../assets/misc/hom.webp";
import rgIcon from "../assets/misc/rg.webp";
import logitIcon from "../assets/logit/icon-light.png";
import {
  absoluteUrl,
  education,
  experiences,
  mapHref,
  profileImage,
  resumeHref,
  selectedProjects,
  siteConfig,
  socialLinks,
} from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const profileWidths = [80, 192, 384, 512, 768, 1024];
const profileSizes = "(max-width: 1023px) 40px, 192px";
const projectWidths = [384, 640, 768, 1024, 1280];
const projectSizes = "(max-width: 1023px) calc(100vw - 2.5rem), 388px";
const projectPreviewAssets = {
  gitproof: gitproofPreview,
  logit: logitPreview,
} as const;

const makeSrcSet = async (src: any, widths: number[], format: "avif" | "webp", quality: number) => {
  const images = await Promise.all(widths.map((width) => getImage({ src, width, format, quality })));

  return {
    src: images[0].src,
    srcSet: images.map((image, index) => `${image.src} ${widths[index]}w`).join(", "),
  };
};

const profileModalAvif = await makeSrcSet(profilePhoto, profileWidths, "avif", 56);
const profileModalWebp = await makeSrcSet(profilePhoto, profileWidths, "webp", 74);
const profileModalFallback = await getImage({ src: profilePhoto, width: 1024, format: "webp", quality: 74 });
const profilePreload = await makeSrcSet(profilePhoto, profileWidths, "avif", 56);
const profileThumbAvif = await makeSrcSet(profilePhoto, [80, 192], "avif", 56);
const profileThumbWebp = await makeSrcSet(profilePhoto, [80, 192], "webp", 74);
const profileThumbFallback = await getImage({ src: profilePhoto, width: 80, format: "webp", quality: 74 });
const profileCardAvif = await makeSrcSet(profilePhoto, [192, 384], "avif", 56);
const profileCardWebp = await makeSrcSet(profilePhoto, [192, 384], "webp", 74);
const profileCardFallback = await getImage({ src: profilePhoto, width: 192, format: "webp", quality: 74 });

const projectsWithImages = await Promise.all(selectedProjects.map(async (project) => {
  const image = projectPreviewAssets[project.imageKey];
  const cardAvif = await makeSrcSet(image, [384, 640, 768], "avif", 58);
  const cardWebp = await makeSrcSet(image, [384, 640, 768], "webp", 76);
  const cardFallback = await getImage({ src: image, width: 640, format: "webp", quality: 76 });
  const modalAvif = await makeSrcSet(image, projectWidths, "avif", 58);
  const modalWebp = await makeSrcSet(image, projectWidths, "webp", 76);
  const modalFallback = await getImage({ src: image, width: 1280, format: "webp", quality: 76 });

  return {
    ...project,
    image,
    cardAvifSrcSet: cardAvif.srcSet,
    cardWebpSrcSet: cardWebp.srcSet,
    cardSrc: cardFallback.src,
    modalAvifSrcSet: modalAvif.srcSet,
    modalWebpSrcSet: modalWebp.srcSet,
    modalSrc: modalFallback.src,
  };
}));

const firstProjectPreload = await makeSrcSet(projectsWithImages[0].image, projectWidths, "avif", 58);
const homIconImage = await getImage({ src: homIcon, width: 96, format: "webp", quality: 92 });
const rgIconImage = await getImage({ src: rgIcon, width: 96, format: "webp", quality: 92 });
const logitMask = await getImage({ src: logitIcon, width: 144, format: "png" });
const imagePreloads = [
  {
    href: profilePreload.src,
    imagesrcset: profilePreload.srcSet,
    imagesizes: profileSizes,
    type: "image/avif",
  },
  {
    href: firstProjectPreload.src,
    imagesrcset: firstProjectPreload.srcSet,
    imagesizes: "388px",
    media: "(min-width: 1024px)",
    type: "image/avif",
  },
];

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: siteConfig.name,
    url: siteConfig.url,
    image: absoluteUrl(profileModalFallback.src),
    email: siteConfig.email,
    jobTitle: siteConfig.jobTitle,
    description: siteConfig.description,
    knowsAbout: siteConfig.keywords,
    sameAs: siteConfig.sameAs,
    homeLocation: {
      "@type": "Place",
      name: siteConfig.location,
    },
    alumniOf: [
      {
        "@type": "CollegeOrUniversity",
        name: "University of California, Los Angeles",
        sameAs: "https://ucla.edu/",
      },
      {
        "@type": "CollegeOrUniversity",
        name: "Mt. San Antonio College",
        sameAs: "https://www.mtsac.edu/",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.name,
    url: siteConfig.url,
    description: siteConfig.description,
    inLanguage: "en-US",
    author: {
      "@type": "Person",
      name: siteConfig.name,
    },
  },
];

const aboutTextClass = "text-gray-600 dark:text-slate-400 lg:text-lg leading-snug";
const sectionHeaderClass =
  "w-fit border theme-border-strong rounded-md px-2 py-1 text-xs uppercase mt-10 mb-5 font-semibold tracking-wider text-nowrap";

const rippleLinks = {
  ucla: {
    href: "https://ucla.edu/",
    text: "UCLA",
    colors: ["#1e3a8a", "#b45309"],
  },
  lindy: {
    href: "https://www.lindy.ai",
    text: "Lindy",
    colors: ["#ffd447", "#573b0a"],
  },
  hci: {
    href: "https://hci.ucla.edu",
    text: "HCI Research Lab",
    colors: ["#1b3783", "#2f68d4"],
  },
  lands: {
    href: "https://en.bandainamcoent.eu/elden-ring/elden-ring",
    text: "Lands Between.",
    colors: ["#092322", "#996A48"],
  },
} as const;

---

<BaseLayout canonicalPath="/" imagePreloads={imagePreloads}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(homeStructuredData)} />

  <div class="page-shell-gutter pt-2 md:pt-4 lg:pt-0 pb-8 lg:pb-0 max-w-5xl mx-auto flex flex-col min-h-screen lg:flex-row lg:gap-7 lg:justify-between page-reveal">
    <div class="lg:py-10">
      <div
        data-mobile-scrim
        class="mobile-page-reveal lg:hidden fixed top-0 left-0 right-0 h-16 z-40 pointer-events-none bg-gradient-to-b from-white/90 via-white/60 to-transparent dark:from-black/90 dark:via-black/60 dark:to-transparent transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]"
        aria-hidden="true"
      ></div>

      <div
        data-mobile-header
        class="mobile-page-reveal page-shell-gutter lg:hidden fixed top-2 left-0 right-0 z-50 flex justify-center pointer-events-none transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]"
      >
        <div class="w-full max-w-5xl pointer-events-auto border theme-border bg-white dark:bg-black rounded-lg flex flex-row items-center justify-between p-3 theme-shadow-md transition-colors duration-300">
          <div class="flex items-center gap-3">
            <button
              data-image-modal-trigger
              data-image-src={profileModalFallback.src}
              data-image-avif-srcset={profileModalAvif.srcSet}
              data-image-webp-srcset={profileModalWebp.srcSet}
              data-image-alt={profileImage.alt}
              data-image-width={profileImage.width}
              data-image-height={profileImage.height}
              data-image-modal-kind="profile"
              class="flex-shrink-0 rounded-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 cursor-pointer"
              aria-label="View full photo of Benjamin Garcia"
              type="button"
            >
              <span class="relative block h-10 w-10 overflow-hidden rounded-lg">
                <picture class="contents">
                  <source type="image/avif" srcset={profileThumbAvif.srcSet} sizes="40px" />
                  <source type="image/webp" srcset={profileThumbWebp.srcSet} sizes="40px" />
                  <img src={profileThumbFallback.src} alt={profileImage.alt} width="40" height="40" sizes="40px" class="h-full w-full object-cover" loading="eager" decoding="async" fetchpriority="high" />
                </picture>
              </span>
            </button>
            <div class="flex flex-col">
              <p class="text-sm font-bold text-gray-900 dark:text-slate-100 leading-tight">
                Benjamin Garcia
              </p>
              <p class="text-[11px] text-gray-500 dark:text-slate-400 font-medium leading-tight">
                I turn code into meaningful creations.
              </p>
            </div>
          </div>

          <button
            data-menu-toggle
            class="relative flex h-10 w-10 items-center justify-center rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500"
            type="button"
            aria-label="Open full-screen menu"
            aria-expanded="false"
          >
            <span data-menu-open-icon><Icon name="menu" size={20} strokeWidth={2.1} class="text-gray-600 dark:text-gray-300" /></span>
            <span data-menu-close-icon class="hidden"><Icon name="x" size={20} strokeWidth={2.1} class="text-gray-600 dark:text-gray-300" /></span>
          </button>
        </div>
      </div>

      <div class="lg:hidden mb-8"></div>

      <div
        data-mobile-menu
        data-open="false"
        data-phase="closed"
        aria-hidden="true"
        inert
        class="mobile-menu-overlay fixed inset-0 z-[60] bg-white dark:bg-black p-6 pt-24 flex flex-col lg:hidden overflow-hidden"
      >
        <div class="page-shell-gutter pointer-events-none absolute top-2 left-0 right-0 z-20 flex justify-center">
          <div class="w-full max-w-5xl rounded-lg border border-transparent flex flex-row items-center justify-between p-3">
            <div class="invisible flex items-center gap-3" aria-hidden="true">
              <div class="h-10 w-10 rounded-lg"></div>
              <div class="flex flex-col">
                <p class="text-sm font-bold leading-tight">Benjamin Garcia</p>
                <p class="text-[11px] font-medium leading-tight">I turn code into meaningful creations.</p>
              </div>
            </div>

            <button
              data-menu-close
              class="pointer-events-auto relative flex h-10 w-10 translate-y-[1px] items-center justify-center rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500"
              type="button"
              aria-label="Close full-screen menu"
            >
              <Icon name="x" size={20} strokeWidth={2.1} class="text-gray-600 dark:text-gray-300" />
            </button>
          </div>
        </div>

        <div class="flex flex-col gap-6 flex-1 justify-center items-center relative z-10">
          {socialLinks.map((link, index) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="pressable social-link-transition mobile-menu-link text-2xl font-semibold text-gray-800 dark:text-slate-200 hover:text-blue-600 dark:hover:text-blue-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 focus-visible:rounded-sm"
              style={`--menu-link-delay: ${40 + index * 30}ms`}
            >
              {link.label}
            </a>
          ))}
          <a
            href={resumeHref}
            target="_blank"
            rel="noopener noreferrer"
            class="pressable social-link-transition mobile-menu-link text-2xl font-semibold text-gray-800 dark:text-slate-200 hover:text-blue-600 dark:hover:text-blue-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 focus-visible:rounded-sm"
            style={`--menu-link-delay: ${40 + socialLinks.length * 30}ms`}
          >
            View Résumé
          </a>
        </div>

        <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none opacity-[0.03] dark:opacity-[0.05] z-0">
          <span class="text-[35vh] font-bold text-black dark:text-white leading-none tracking-tighter pr-6">bg</span>
        </div>
      </div>

      <aside class="hidden lg:flex flex-col lg:w-[204px] lg:shrink-0 lg:gap-y-3 lg:sticky lg:top-10 h-fit">
        <div class="bg-white dark:bg-black rounded-xl theme-shadow-md p-2 transition-colors duration-300">
          <div class="relative group/img">
            <picture>
              <source type="image/avif" srcset={profileCardAvif.srcSet} sizes="192px" />
              <source type="image/webp" srcset={profileCardWebp.srcSet} sizes="192px" />
              <img
                src={profileCardFallback.src}
                alt={profileImage.alt}
                width={profileImage.width}
                height={profileImage.height}
                loading="eager"
                decoding="async"
                sizes="192px"
                fetchpriority="high"
                class="h-auto w-full rounded-xl mb-2"
                style="height: auto"
              />
            </picture>
            <button
              data-image-modal-trigger
              data-image-src={profileModalFallback.src}
              data-image-avif-srcset={profileModalAvif.srcSet}
              data-image-webp-srcset={profileModalWebp.srcSet}
              data-image-alt={profileImage.alt}
              data-image-width={profileImage.width}
              data-image-height={profileImage.height}
              data-image-modal-kind="profile"
              class="absolute top-2 right-2 p-1.5 rounded-md bg-black/40 backdrop-blur-sm text-white/80 hover:text-white hover:bg-black/60 opacity-0 group-hover/img:opacity-100 transition-all duration-300 ease-in-out cursor-pointer focus-visible:opacity-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500"
              aria-label="Expand photo"
              title="Expand photo"
              type="button"
            >
              <Icon name="expand" size={14} strokeWidth={2.5} />
            </button>
          </div>

          <div class="p-1">
            <p class="text-gray-900 dark:text-slate-100 text-2xl font-semibold tracking-tight leading-none">Hello, I'm</p>
            <p class="text-gray-900 dark:text-slate-100 text-2xl font-semibold tracking-tight">Benjamin Garcia</p>
            <p class="text-gray-700 dark:text-slate-300 text-base leading-tight mt-2 font-normal">I turn code into meaningful creations.</p>
            <div class="flex flex-row gap-1 items-center mt-2">
              <Icon name="map-pin" size={16} class="text-gray-500 dark:text-slate-400" />
              <a class="text-sm text-gray-500 dark:text-slate-400 hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 focus-visible:rounded-sm" href={mapHref} target="_blank" rel="noopener noreferrer">
                Los Angeles, CA
              </a>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-black rounded-xl theme-shadow-md p-2 transition-colors duration-300">
          <div class="grid grid-cols-4 gap-2 mb-2">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                title={link.label}
                class="pressable social-link-transition group/social flex items-center justify-center aspect-square rounded-md bg-gray-50 dark:bg-gray-950 text-gray-600 dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-gray-900 hover:text-black dark:hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500"
              >
                {link.icon === "logit" ? (
                  <span aria-hidden="true" class="block h-5 w-5 bg-current" style={`mask: url('${logitMask.src}') center / contain no-repeat; -webkit-mask: url('${logitMask.src}') center / contain no-repeat;`}></span>
                ) : (
                  <Icon name={link.icon} size={18} />
                )}
              </a>
            ))}
          </div>

          <a
            class="pressable social-link-transition group flex items-center justify-center gap-1 bg-gray-50 dark:bg-gray-950 text-gray-600 dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-gray-900 hover:text-black dark:hover:text-white rounded-md px-4 py-2 text-sm font-semibold w-full text-center focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500"
            href={resumeHref}
            target="_blank"
            rel="noopener noreferrer"
            title="Resume"
          >
            View My Résumé
            <Icon name="arrow-up-right" size={14} class="transform transition-transform duration-300 group-hover:translate-x-[0.5px] group-hover:-translate-y-[0.5px]" />
          </a>
        </div>
      </aside>
    </div>

    <main aria-labelledby="home-heading" class="flex-1 flex-col lg:w-2/3 lg:py-13 pt-6">
      <h1 id="home-heading" class="sr-only">{siteConfig.title}</h1>

      <section id="about" aria-labelledby="about-heading" class="flex flex-col">
        <div class="flex flex-row justify-between items-center">
          <h2 id="about-heading" class={`${sectionHeaderClass} lg:mt-0`}>about</h2>
          <label
            data-theme-toggle
            for="site-theme-input"
            role="button"
            tabindex="0"
            aria-label="Toggle dark mode"
            class="pressable group relative w-fit border theme-border-strong rounded-md pl-1 pr-2 py-1 text-xs uppercase mt-10 mb-5 lg:mt-0 lg:mb-5 font-semibold tracking-wider flex flex-row items-center gap-0.5 hover:cursor-pointer transition-colors duration-300 ease-[var(--theme-transition-ease)]"
          >
            <span class="relative flex h-4 w-4 items-center justify-center pb-[1px]">
              <span data-theme-moon class="absolute grid place-items-center pb-[0.5px]"><Icon name="moon" size={12} strokeWidth={2} class="transform-gpu transition-[opacity,scale,rotate] duration-300 ease-[var(--theme-transition-ease)]" /></span>
              <span data-theme-sun class="absolute grid place-items-center"><Icon name="sun" size={12} strokeWidth={2} class="transform-gpu transition-[opacity,scale,rotate] duration-300 ease-[var(--theme-transition-ease)]" /></span>
            </span>
            <span data-theme-label class="transition-opacity duration-300 ease-[var(--theme-transition-ease)]">Dark</span>
          </label>
        </div>

        <p class={aboutTextClass}>
          I'm a junior studying Computer Science at{" "}
          <RippleLink {...rippleLinks.ucla} />. This summer, I'm joining{" "}
          <RippleLink {...rippleLinks.lindy} /> as a software engineering intern, and I also conduct research in UCLA's{" "}
          <RippleLink {...rippleLinks.hci} />, where I explore AI systems for scientific hypothesis generation. I care deeply about building responsive, accessible interfaces that make complex systems feel clear and usable.
        </p>

        <p class={`${aboutTextClass} mt-2`}>
          Outside of building, I enjoy weightlifting, time with my dog, and exploring the{" "}
          <RippleLink {...rippleLinks.lands} />
        </p>
      </section>

      <section id="experience" aria-labelledby="experience-heading" class="flex flex-col">
        <h2 id="experience-heading" class={sectionHeaderClass}>experience</h2>
        <div class="flex flex-col gap-4">
          {experiences.map((item) => <Dropdown item={item} />)}
        </div>
      </section>

      <section id="projects" aria-labelledby="projects-heading">
        <div class="flex flex-row justify-between">
          <h2 id="projects-heading" class={sectionHeaderClass}>selected projects</h2>
          <a href="/archive" class="pressable group w-fit border theme-border-strong rounded-md px-2 py-1 uppercase mt-10 mb-5 font-semibold tracking-wider text-xs flex items-center gap-1 text-center focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500">
            project archive
            <Icon name="arrow-right" size={12} class="transform transition-transform duration-300 group-hover:translate-x-[0.5px] pb-[0.5px]" />
          </a>
        </div>
        <div class="grid items-start gap-4 lg:grid-cols-2">
          {projectsWithImages.map((project, index) => (
            <article class="overflow-hidden rounded-xl border theme-border bg-white theme-shadow-sm transition-colors duration-300 dark:bg-black">
              <div class="group/img relative aspect-[16/9] w-full overflow-hidden border-b theme-border">
                <picture class="block h-full w-full">
                  <source type="image/avif" srcset={project.cardAvifSrcSet} sizes={projectSizes} />
                  <source type="image/webp" srcset={project.cardWebpSrcSet} sizes={projectSizes} />
                  <img src={project.cardSrc} alt={project.title} width={project.width} height={project.height} loading={index === 0 ? "eager" : "lazy"} decoding="async" fetchpriority={index === 0 ? "high" : "auto"} sizes={projectSizes} class="h-full w-full object-cover" />
                </picture>
                <button
                  data-image-modal-trigger
                  data-image-src={project.modalSrc}
                  data-image-avif-srcset={project.modalAvifSrcSet}
                  data-image-webp-srcset={project.modalWebpSrcSet}
                  data-image-alt={project.title}
                  data-image-width={project.width}
                  data-image-height={project.height}
                  class="absolute top-3 right-3 flex items-center justify-center rounded-md bg-black/40 p-1.5 text-white/80 opacity-0 backdrop-blur-sm cursor-pointer transition-all duration-300 ease-in-out group-hover/img:opacity-100 focus-visible:opacity-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500"
                  aria-label={`Expand ${project.title}`}
                  title="Expand photo"
                  type="button"
                >
                  <Icon name="expand" size={14} strokeWidth={2.5} />
                </button>
              </div>

              <div class="p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 flex-1 pr-2">
                    <h3 class="text-lg font-semibold text-gray-900 md:text-xl dark:text-slate-100">{project.title}</h3>
                  </div>
                  <div class="flex shrink-0 items-center gap-3 pl-2">
                    <a href={project.link} target="_blank" rel="noopener noreferrer" class="flex items-center text-gray-600 transition-colors duration-300 hover:text-gray-900 focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 dark:text-slate-400 dark:hover:text-slate-200" title="Visit Site" aria-label={`Visit ${project.title}`}>
                      <Icon name="globe" size={16} />
                    </a>
                    <a href={project.githubLink} target="_blank" rel="noopener noreferrer" class="flex items-center text-gray-600 transition-colors duration-300 hover:text-gray-900 focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 dark:text-slate-400 dark:hover:text-slate-200" title="View on GitHub" aria-label={`View ${project.title} on GitHub`}>
                      <Icon name="github" size={18} />
                    </a>
                  </div>
                </div>
                <p class="mt-1 text-sm text-gray-600 line-clamp-2 lg:min-h-[4rem] lg:text-base dark:text-slate-400">{project.summary}</p>
                <div class="mt-5 flex flex-wrap gap-2 lg:mt-0">
                  {project.tags.map((tag) => (
                    <span class="whitespace-nowrap rounded-full border theme-border bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-500 transition-colors duration-300 dark:bg-gray-900 dark:text-slate-300">{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="education" aria-labelledby="education-heading" class="mt-10">
        <h2 id="education-heading" class={sectionHeaderClass}>education</h2>
        <div class="flex flex-col gap-4">
          {education.map((item) => <Dropdown item={item} />)}
        </div>
      </section>

      <section id="closing-note">
        <div class="w-full justify-between flex flex-col sm:flex-row items-center text-center pt-16 gap-3">
          <div class="flex flex-row gap-3">
            <button data-youtube-trigger data-video-id="YWdbfy231n0" type="button" class="pressable relative cursor-pointer p-1 md:p-2 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 focus-visible:rounded-md" aria-label="Watch Malenia video">
              <img src={homIconImage.src} width="48" height="48" sizes="(min-width: 768px) 48px, 36px" alt="Watch me defeat Malenia!" class="inline-block w-9 h-9 md:w-12 md:h-12" loading="lazy" decoding="async" />
            </button>
            <button data-youtube-trigger data-video-id="NaVNh79V4F4" type="button" class="pressable relative cursor-pointer p-1 md:p-2 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 focus-visible:rounded-md" aria-label="Watch Radahn video">
              <img src={rgIconImage.src} width="48" height="48" sizes="(min-width: 768px) 48px, 36px" alt="Watch me defeat Promised Consort Radahn!" class="inline-block w-9 h-9 md:w-12 md:h-12" loading="lazy" decoding="async" />
            </button>
          </div>

          <div class="md:text-right max-w-full sm:max-w-[365px] md:ml-auto text-gray-600 dark:text-slate-400 text-sm">
            <p>
              Loosely inspired by <FooterLink href="https://www.framer.com/marketplace/templates/monocv/">MonoCV</FooterLink> and coded in <FooterLink href="https://code.visualstudio.com/">Visual Studio Code</FooterLink>. Built with <FooterLink href="https://astro.build/">Astro</FooterLink> and <FooterLink href="https://tailwindcss.com/">Tailwind</FooterLink>, deployed with <FooterLink href="https://vercel.com/">Vercel</FooterLink>. <span class="sm:hidden">All text is in</span>{" "}
              <span class="sm:hidden"><FooterLink href="https://www.fontshare.com/fonts/cabinet-grotesk">Cabinet Grotesk</FooterLink> typeface.</span>
            </p>
            <p class="hidden sm:block">All text is in <FooterLink href="https://www.fontshare.com/fonts/cabinet-grotesk">Cabinet Grotesk</FooterLink> typeface.</p>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div data-image-modal data-open="false" data-phase="closed" class="image-modal-overlay fixed inset-0 z-[70] items-center justify-center p-4 bg-black/80 backdrop-blur-sm" role="dialog" aria-modal="true" aria-label="Expanded image preview" inert>
    <div data-image-modal-content class="image-modal-content relative w-full max-w-5xl">
      <button data-image-modal-close class="absolute top-2 right-2 z-10 p-2 text-gray-100 hover:text-white transition-colors duration-300 bg-black/60 rounded-full backdrop-blur-sm hover:bg-black/80 cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500" aria-label="Close image preview" type="button">
        <Icon name="x" size={20} />
      </button>
      <picture>
        <source data-image-modal-avif type="image/avif" />
        <source data-image-modal-webp type="image/webp" />
        <img data-image-modal-img src="" alt="" width="2048" height="1277" class="image-modal-img h-auto w-auto max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl select-none" style="width: auto; height: auto" draggable="false" decoding="async" />
      </picture>
    </div>
  </div>

  <div data-video-modal class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/75 backdrop-blur-sm" role="dialog" aria-modal="true" aria-label="Video preview">
    <div class="relative w-full max-w-4xl bg-gray-900 rounded-lg overflow-hidden shadow-2xl modal-scale">
      <button data-video-modal-close class="absolute top-2 -right-2 -translate-x-1/2 z-10 p-2 text-gray-100 hover:text-white transition-colors duration-300 bg-black/10 rounded-full backdrop-blur-sm hover:bg-black/50 cursor-pointer" aria-label="Close video" type="button">
        <Icon name="x" size={24} />
      </button>
      <div class="aspect-video w-full">
        <iframe data-video-frame src="" class="w-full h-full" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
    </div>
  </div>

  <script>
    // @ts-nocheck
    const root = document.documentElement;
    const body = document.body;
    const themeInput = document.querySelector("[data-theme-input]");
    const themeColors = {
      light: "#ffffff",
      dark: "#000000",
    };
    const syncThemeColor = (theme) => {
      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) {
        meta.content = themeColors[theme] || themeColors.light;
      }
    };
    const syncThemeButton = () => {
      const isDark = Boolean(themeInput?.checked);
      const theme = isDark ? "dark" : "light";
      root.dataset.theme = theme;
      syncThemeColor(theme);
      document.querySelectorAll("[data-theme-label]").forEach((label) => {
        label.textContent = isDark ? "Light" : "Dark";
      });
      document.querySelectorAll("[data-theme-moon]").forEach((icon) => {
        icon.classList.toggle("opacity-0", isDark);
        icon.classList.toggle("rotate-90", isDark);
        icon.classList.toggle("scale-0", isDark);
      });
      document.querySelectorAll("[data-theme-sun]").forEach((icon) => {
        icon.classList.toggle("opacity-0", !isDark);
        icon.classList.toggle("-rotate-90", !isDark);
        icon.classList.toggle("scale-0", !isDark);
      });
    };

    syncThemeButton();
    let themeTransitionTimer = null;
    themeInput?.addEventListener("change", () => {
      const nextTheme = themeInput.checked ? "dark" : "light";
      if (themeTransitionTimer) window.clearTimeout(themeTransitionTimer);
      root.classList.add("theme-changing");
      root.dataset.theme = nextTheme;
      localStorage.setItem("theme", nextTheme);
      syncThemeButton();
      themeTransitionTimer = window.setTimeout(() => {
        root.classList.remove("theme-changing");
      }, 360);
    });
    document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
      button.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          button.click();
        }
      });
    });

    document.querySelectorAll("[data-dropdown-trigger]").forEach((trigger) => {
      const dropdown = trigger.closest("[data-dropdown]");
      const setPressed = (pressed) => {
        dropdown?.classList.toggle("is-pressed", pressed);
      };
      trigger.addEventListener("click", () => {
        const isOpen = dropdown?.dataset.open === "true";
        if (dropdown) animateDropdown(dropdown, !isOpen);
        trigger.setAttribute("aria-expanded", String(!isOpen));
        dropdown?.querySelector("[data-dropdown-chevron]")?.classList.toggle("hidden", !isOpen);
        dropdown?.querySelector("[data-dropdown-x]")?.classList.toggle("hidden", isOpen);
      });
      trigger.addEventListener("pointerdown", () => setPressed(true));
      trigger.addEventListener("pointerup", () => setPressed(false));
      trigger.addEventListener("pointerleave", () => setPressed(false));
      trigger.addEventListener("pointercancel", () => setPressed(false));
      trigger.addEventListener("blur", () => setPressed(false));
      trigger.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          setPressed(true);
        }
      });
      trigger.addEventListener("keyup", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          setPressed(false);
          trigger.click();
        }
      });
    });
    document.querySelectorAll("[data-dropdown] a").forEach((link) => {
      link.addEventListener("click", (event) => event.stopPropagation());
      link.addEventListener("pointerdown", (event) => event.stopPropagation());
      link.addEventListener("keydown", (event) => event.stopPropagation());
      link.addEventListener("keyup", (event) => event.stopPropagation());
    });

    const dropdownAnimations = new WeakMap();
    const animateDropdown = (dropdown, open) => {
      const content = dropdown.querySelector("[data-dropdown-content]");
      if (!content) return;

      const previousAnimation = dropdownAnimations.get(content);
      if (previousAnimation) cancelAnimationFrame(previousAnimation);

      const fromHeight = content.getBoundingClientRect().height;
      content.style.height = open ? "auto" : `${fromHeight}px`;
      const toHeight = open ? content.scrollHeight : 0;
      const fromOpacity = Number(getComputedStyle(content).opacity || 0);
      const toOpacity = open ? 1 : 0;

      dropdown.dataset.open = String(open);
      content.style.height = `${fromHeight}px`;
      content.style.opacity = String(fromOpacity);

      const stiffness = 300;
      const damping = 30;
      const mass = 1;
      let position = 0;
      let velocity = 0;
      let lastTime = performance.now();

      const step = (time) => {
        const deltaSeconds = Math.min((time - lastTime) / 1000, 0.05);
        lastTime = time;

        const displacement = position - 1;
        const springForce = -stiffness * displacement;
        const dampingForce = -damping * velocity;
        const acceleration = (springForce + dampingForce) / mass;

        velocity += acceleration * deltaSeconds;
        position += velocity * deltaSeconds;

        const progress = Math.max(0, Math.min(1, position));
        content.style.height = `${fromHeight + (toHeight - fromHeight) * progress}px`;
        content.style.opacity = String(fromOpacity + (toOpacity - fromOpacity) * progress);

        if (Math.abs(velocity) < 0.01 && Math.abs(1 - position) < 0.01) {
          content.style.opacity = String(toOpacity);
          content.style.height = open ? "auto" : "0px";
          dropdownAnimations.delete(content);
          return;
        }

        dropdownAnimations.set(content, requestAnimationFrame(step));
      };

      dropdownAnimations.set(content, requestAnimationFrame(step));
    };

    const imageModal = document.querySelector("[data-image-modal]");
    const imageModalContent = document.querySelector("[data-image-modal-content]");
    const imageModalImg = document.querySelector("[data-image-modal-img]");
    const imageModalAvif = document.querySelector("[data-image-modal-avif]");
    const imageModalWebp = document.querySelector("[data-image-modal-webp]");
    let lastImageTrigger = null;
    let imageModalCloseTimer = null;
    let imageModalOpenFrame = null;
    const imageModalDuration = 360;
    const modalImagePreloads = new Map();
    const preloadModalImage = (trigger) => {
      const src = trigger.dataset.imageSrc || "";
      const srcset = trigger.dataset.imageAvifSrcset || trigger.dataset.imageWebpSrcset || "";
      if (!src && !srcset) return;
      const isProfileImage = trigger.dataset.imageModalKind === "profile";
      const sizes = isProfileImage ? "(max-width: 512px) 100vw, 512px" : "(max-width: 1024px) 100vw, 1024px";
      const cacheKey = `${srcset}|${src}|${sizes}`;
      if (modalImagePreloads.has(cacheKey)) return;

      const image = new Image();
      image.decoding = "async";
      image.loading = "eager";
      image.fetchPriority = "low";
      image.sizes = sizes;
      if (srcset) image.srcset = srcset;
      if (src) image.src = src;
      modalImagePreloads.set(cacheKey, image);
    };
    const preloadModalImages = () => {
      const triggers = Array.from(document.querySelectorAll("[data-image-modal-trigger]"));
      let index = 0;
      const preloadNext = () => {
        const trigger = triggers[index];
        index += 1;
        if (trigger instanceof HTMLElement) preloadModalImage(trigger);
        if (index < triggers.length) window.setTimeout(preloadNext, 80);
      };
      preloadNext();
    };
    const scheduleModalImagePreloads = () => {
      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(() => {
          if ("requestIdleCallback" in window) {
            window.requestIdleCallback(preloadModalImages, { timeout: 1500 });
          } else {
            window.setTimeout(preloadModalImages, 500);
          }
        });
      });
    };
    const closeImageModal = () => {
      if (!imageModal || imageModal.dataset.open !== "true") return;
      if (imageModalCloseTimer) window.clearTimeout(imageModalCloseTimer);
      if (imageModalOpenFrame) window.cancelAnimationFrame(imageModalOpenFrame);
      imageModal.dataset.open = "false";
      imageModal.dataset.phase = "closing";
      imageModal.setAttribute("aria-hidden", "true");
      imageModal.setAttribute("inert", "");
      imageModalCloseTimer = window.setTimeout(() => {
        if (imageModal.dataset.open === "true") return;
        imageModal.dataset.phase = "closed";
        body.style.overflow = "";
        if (imageModalAvif instanceof HTMLSourceElement) imageModalAvif.srcset = "";
        if (imageModalWebp instanceof HTMLSourceElement) imageModalWebp.srcset = "";
        if (imageModalImg instanceof HTMLImageElement) {
          imageModalImg.removeAttribute("srcset");
          imageModalImg.src = "";
        }
        lastImageTrigger?.focus?.();
      }, imageModalDuration);
    };
    document.querySelectorAll("[data-image-modal-trigger]").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        lastImageTrigger = trigger;
        const isProfileImage = trigger.dataset.imageModalKind === "profile";
        if (imageModalContent instanceof HTMLElement) {
          imageModalContent.dataset.imageKind = isProfileImage ? "profile" : "project";
        }
        imageModalContent?.classList.toggle("max-w-lg", isProfileImage);
        imageModalContent?.classList.toggle("max-w-5xl", !isProfileImage);
        if (imageModalAvif instanceof HTMLSourceElement) {
          imageModalAvif.srcset = trigger.dataset.imageAvifSrcset || "";
          imageModalAvif.sizes = isProfileImage ? "(max-width: 639px) 18rem, 512px" : "(max-width: 639px) 21rem, 1024px";
        }
        if (imageModalWebp instanceof HTMLSourceElement) {
          imageModalWebp.srcset = trigger.dataset.imageWebpSrcset || "";
          imageModalWebp.sizes = isProfileImage ? "(max-width: 639px) 18rem, 512px" : "(max-width: 639px) 21rem, 1024px";
        }
        if (imageModalImg instanceof HTMLImageElement) {
          imageModalImg.src = trigger.dataset.imageSrc || "";
          imageModalImg.alt = trigger.dataset.imageAlt || "Expanded image preview";
          imageModalImg.width = Number(trigger.dataset.imageWidth || 2048);
          imageModalImg.height = Number(trigger.dataset.imageHeight || 1277);
          imageModalImg.sizes = isProfileImage ? "(max-width: 512px) 100vw, 512px" : "(max-width: 1024px) 100vw, 1024px";
        }
        if (imageModalCloseTimer) window.clearTimeout(imageModalCloseTimer);
        if (imageModalOpenFrame) window.cancelAnimationFrame(imageModalOpenFrame);
        if (imageModal) {
          imageModal.dataset.open = "false";
          imageModal.dataset.phase = "opening";
          imageModal.setAttribute("aria-hidden", "false");
          imageModal.removeAttribute("inert");
          imageModalOpenFrame = window.requestAnimationFrame(() => {
            imageModalOpenFrame = window.requestAnimationFrame(() => {
              if (!imageModal) return;
              imageModal.dataset.open = "true";
              imageModal.dataset.phase = "open";
            });
          });
        }
        body.style.overflow = "hidden";
        imageModal?.querySelector("button")?.focus();
      });
    });
    imageModal?.addEventListener("click", (event) => {
      if (event.target === imageModal) closeImageModal();
    });
    document.querySelector("[data-image-modal-close]")?.addEventListener("click", closeImageModal);
    if (document.readyState === "complete") {
      scheduleModalImagePreloads();
    } else {
      window.addEventListener("load", scheduleModalImagePreloads, { once: true });
    }

    const videoModal = document.querySelector("[data-video-modal]");
    const videoFrame = document.querySelector("[data-video-frame]");
    const closeVideoModal = () => {
      videoModal?.classList.add("hidden");
      videoModal?.classList.remove("flex");
      if (videoFrame instanceof HTMLIFrameElement) videoFrame.src = "";
      body.style.overflow = "";
    };
    document.querySelectorAll("[data-youtube-trigger]").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const id = trigger.dataset.videoId;
        if (videoFrame instanceof HTMLIFrameElement && id) {
          videoFrame.src = `https://www.youtube.com/embed/${id}?autoplay=1&controls=1&modestbranding=1&rel=0&showinfo=0&fs=1`;
        }
        videoModal?.classList.remove("hidden");
        videoModal?.classList.add("flex");
        body.style.overflow = "hidden";
      });
    });
    videoModal?.addEventListener("click", (event) => {
      if (event.target === videoModal) closeVideoModal();
    });
    document.querySelector("[data-video-modal-close]")?.addEventListener("click", closeVideoModal);

    const menu = document.querySelector("[data-mobile-menu]");
    const menuToggle = document.querySelector("[data-menu-toggle]");
    const openIcon = document.querySelector("[data-menu-open-icon]");
    const closeIcon = document.querySelector("[data-menu-close-icon]");
    let menuCloseTimer = null;
    const setMenu = (open) => {
      if (menu) {
        if (menuCloseTimer) window.clearTimeout(menuCloseTimer);
        menu.dataset.open = String(open);
        menu.dataset.phase = open ? "open" : "closing";
        menu.setAttribute("aria-hidden", String(!open));
        if (open) {
          menu.removeAttribute("inert");
        } else {
          menu.setAttribute("inert", "");
          menuCloseTimer = window.setTimeout(() => {
            if (menu.dataset.open !== "true") menu.dataset.phase = "closed";
          }, 340);
        }
      }
      body.style.overflow = open ? "hidden" : "";
      menuToggle?.setAttribute("aria-expanded", String(open));
      menuToggle?.setAttribute("aria-label", open ? "Close full-screen menu" : "Open full-screen menu");
      openIcon?.classList.toggle("hidden", open);
      closeIcon?.classList.toggle("hidden", !open);
    };
    menuToggle?.addEventListener("click", () => setMenu(menu?.dataset.open !== "true"));
    document.querySelector("[data-menu-close]")?.addEventListener("click", () => setMenu(false));

    let lastScrollY = window.scrollY;
    let directionAnchorY = window.scrollY;
    let scrollDirection = null;
    let scrollFrame = null;
    let headerVisible = true;
    const mobileHeader = document.querySelector("[data-mobile-header]");
    const mobileScrim = document.querySelector("[data-mobile-scrim]");
    const setHeaderVisible = (visible) => {
      headerVisible = visible;
      mobileScrim?.classList.toggle("opacity-0", !visible);
      mobileScrim?.classList.toggle("-translate-y-6", !visible);
      mobileHeader?.classList.toggle("opacity-0", !visible);
      mobileHeader?.classList.toggle("-translate-y-24", !visible);
      mobileHeader?.classList.toggle("pointer-events-none", !visible);
    };
    const resetScrollTracking = () => {
      lastScrollY = window.scrollY;
      directionAnchorY = window.scrollY;
      scrollDirection = null;
    };
    window.addEventListener("scroll", () => {
      if (scrollFrame !== null) return;
      scrollFrame = requestAnimationFrame(() => {
        scrollFrame = null;
        if (window.matchMedia("(min-width: 1024px)").matches || menu?.dataset.open === "true" || imageModal?.classList.contains("flex")) {
          resetScrollTracking();
          return;
        }

        const minDelta = 3;
        const topRevealOffset = 32;
        const hideStartOffset = 88;
        const toggleAfter = 48;

      const current = window.scrollY;
        const delta = current - lastScrollY;
        lastScrollY = current;
        if (Math.abs(delta) < minDelta) return;

        if (current <= topRevealOffset) {
          directionAnchorY = current;
          scrollDirection = null;
        setHeaderVisible(true);
          return;
        }

        const direction = delta > 0 ? "down" : "up";
        if (scrollDirection !== direction) {
          scrollDirection = direction;
          directionAnchorY = current;
        }

        const travelSinceDirectionChange = Math.abs(current - directionAnchorY);

        if (direction === "down" && headerVisible && current >= hideStartOffset && travelSinceDirectionChange >= toggleAfter) {
          directionAnchorY = current;
          setHeaderVisible(false);
        }

        if (direction === "up" && !headerVisible && travelSinceDirectionChange >= toggleAfter) {
          directionAnchorY = current;
          setHeaderVisible(true);
        }
      });
    }, { passive: true });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeImageModal();
        closeVideoModal();
        setMenu(false);
      }
    });
  </script>
</BaseLayout>
