---
type Props = {
  alt: string;
  darkSrc?: string;
  eager?: boolean;
  href?: string;
  src: string;
};

const { alt, darkSrc, eager = false, href, src } = Astro.props;
const Wrapper = href ? "a" : "span";
---

<Wrapper
  href={href}
  target={href ? "_blank" : undefined}
  rel={href ? "noopener noreferrer" : undefined}
  class:list={["relative z-10 flex items-center justify-center rounded-xl", href && "focus-ring"]}
>
  <span class:list={["dropdown-logo-frame flex", darkSrc && "dark:hidden"]}>
    <span class="relative h-full w-full overflow-hidden rounded-lg">
      <img
        src={src}
        alt={alt}
        width="60"
        height="60"
        sizes="60px"
        loading={eager ? "eager" : "lazy"}
        decoding="async"
        class="h-full w-full object-cover"
      />
    </span>
  </span>
  {darkSrc && (
    <span class="dropdown-logo-frame hidden dark:flex">
      <span class="relative h-full w-full overflow-hidden rounded-lg">
        <img
          src={darkSrc}
          alt={alt}
          width="60"
          height="60"
          sizes="60px"
          loading="eager"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </span>
    </span>
  )}
</Wrapper>
