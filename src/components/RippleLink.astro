---
type Props = {
  href: string;
  text: string;
};

const { href, text } = Astro.props;
---

<a
  class="font-medium text-gray-700 transition-colors duration-200 ease-out hover:text-gray-900 focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 dark:text-slate-300 dark:hover:text-slate-100"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  {text}
</a>
