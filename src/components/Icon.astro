---
type Props = {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
};

const { name, size = 16, class: className, strokeWidth = 2 } = Astro.props;
const strokeProps = {
  fill: "none",
  stroke: "currentColor",
  "stroke-width": strokeWidth,
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
} as const;
---

{name === "mail" && (
  <svg width={size} height={size} viewBox="0 0 24 24" class={className} {...strokeProps}>
    <rect width="20" height="16" x="2" y="4" rx="2"></rect>
    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
  </svg>
)}
{name === "map-pin" && (
