---
import { getImage } from "astro:assets";
import DropdownLogo from "./DropdownLogo.astro";
import Icon from "./Icon.astro";
import type { ImageMetadata } from "astro";

type Props = {
  item: {
    role: string;
    position: string;
    startDate: string;
    endDate?: string;
    src: ImageMetadata;
    darkSrc?: ImageMetadata;
    imageLink?: string;
    description?: string;
  };
};

const { item } = Astro.props;
const dateText = `${item.startDate}${item.endDate ? ` - ${item.endDate}` : ""}`;
const logo = await getImage({ src: item.src, width: 120, height: 120, format: "webp", quality: 92 });
const darkLogo = item.darkSrc
  ? await getImage({ src: item.darkSrc, width: 120, height: 120, format: "webp", quality: 92 })
  : null;
---

<div
  data-dropdown
  data-open="false"
  class="pressable dropdown-card"
>
  <div class="flex select-none flex-row">
    <div class="flex items-center justify-center">
      <DropdownLogo
        alt={`${item.position} logo`}
        darkSrc={darkLogo?.src}
        eager={Boolean(item.darkSrc)}
        href={item.imageLink}
        src={logo.src}
      />
    </div>
    <button data-dropdown-trigger type="button" aria-expanded="false" class="flex w-full items-center justify-between gap-2 bg-transparent py-1.5 pr-1.5 pl-1 text-left sm:py-2 sm:pr-2 sm:pl-1.5 lg:gap-3">
      <div class="flex min-w-0 flex-col">
        <span class="w-full font-semibold text-gray-900 dark:text-slate-100 lg:text-lg">{item.role}</span>
        <div class="flex flex-row items-center">
          <span class="text-sm text-gray-600 dark:text-slate-400 lg:text-base">{item.position}</span>
        </div>
      </div>
      <div class="flex shrink-0 flex-row items-center">
        <p class="hidden text-sm text-gray-600 dark:text-slate-400 sm:block lg:text-base">{dateText}</p>
        <div class="ml-1 rounded-3xl transition-all duration-300 ease-in-out sm:ml-2">
          <div class="grid h-4 w-4 place-items-center">
            <span data-dropdown-chevron><Icon name="chevron-down" size={14} strokeWidth={1} class="block text-gray-600 dark:text-slate-400" /></span>
            <span data-dropdown-x class="hidden"><Icon name="x" size={14} strokeWidth={1} class="block text-gray-600 dark:text-slate-400" /></span>
          </div>
        </div>
      </div>
    </button>
  </div>
  <div data-dropdown-content class="dropdown-content">
    <div class="overflow-hidden">
      <div class="border-t theme-border p-4">
        <p class="text-sm text-gray-800 dark:text-slate-200 lg:text-base">{item.description}</p>
      </div>
    </div>
  </div>
</div>

<script>
  const dropdownAnimations = new WeakMap<Element, number>();
  const animateDropdown = (dropdown: HTMLElement, open: boolean) => {
    const content = dropdown.querySelector<HTMLElement>("[data-dropdown-content]");
    if (!content) return;

    const previousAnimation = dropdownAnimations.get(content);
    if (previousAnimation) cancelAnimationFrame(previousAnimation);

    const fromHeight = content.getBoundingClientRect().height;
    content.style.height = open ? "auto" : `${fromHeight}px`;
    const toHeight = open ? content.scrollHeight : 0;
    const fromOpacity = Number(getComputedStyle(content).opacity || 0);
    const toOpacity = open ? 1 : 0;

    dropdown.dataset.open = String(open);
    content.style.height = `${fromHeight}px`;
    content.style.opacity = String(fromOpacity);

    const stiffness = 300;
    const damping = 30;
    const mass = 1;
    let position = 0;
    let velocity = 0;
    let lastTime = performance.now();

    const step = (time: number) => {
      const deltaSeconds = Math.min((time - lastTime) / 1000, 0.05);
      lastTime = time;

      const displacement = position - 1;
      const springForce = -stiffness * displacement;
      const dampingForce = -damping * velocity;
      const acceleration = (springForce + dampingForce) / mass;

      velocity += acceleration * deltaSeconds;
      position += velocity * deltaSeconds;

      const progress = Math.max(0, Math.min(1, position));
      content.style.height = `${fromHeight + (toHeight - fromHeight) * progress}px`;
      content.style.opacity = String(fromOpacity + (toOpacity - fromOpacity) * progress);

      if (Math.abs(velocity) < 0.01 && Math.abs(1 - position) < 0.01) {
        content.style.opacity = String(toOpacity);
        content.style.height = open ? "auto" : "0px";
        dropdownAnimations.delete(content);
        return;
      }

      dropdownAnimations.set(content, requestAnimationFrame(step));
    };

    dropdownAnimations.set(content, requestAnimationFrame(step));
  };

  document.querySelectorAll<HTMLElement>("[data-dropdown-trigger]").forEach((trigger) => {
    if (trigger.dataset.dropdownBound === "true") return;
    trigger.dataset.dropdownBound = "true";

    const dropdown = trigger.closest<HTMLElement>("[data-dropdown]");
    const setPressed = (pressed: boolean) => {
      dropdown?.classList.toggle("is-pressed", pressed);
    };

    trigger.addEventListener("click", () => {
      const isOpen = dropdown?.dataset.open === "true";
      if (dropdown) animateDropdown(dropdown, !isOpen);
      trigger.setAttribute("aria-expanded", String(!isOpen));
      dropdown?.querySelector("[data-dropdown-chevron]")?.classList.toggle("hidden", !isOpen);
      dropdown?.querySelector("[data-dropdown-x]")?.classList.toggle("hidden", isOpen);
    });
    trigger.addEventListener("pointerdown", () => setPressed(true));
    trigger.addEventListener("pointerup", () => setPressed(false));
    trigger.addEventListener("pointerleave", () => setPressed(false));
    trigger.addEventListener("pointercancel", () => setPressed(false));
    trigger.addEventListener("blur", () => setPressed(false));
    trigger.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") setPressed(true);
    });
    trigger.addEventListener("keyup", (event) => {
      if (event.key === "Enter" || event.key === " ") setPressed(false);
    });
  });
</script>
