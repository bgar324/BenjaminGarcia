---
import "../styles/globals.css";
import { defaultOpenGraphImage, defaultTwitterImage, siteConfig } from "../data/site";
import cabinetGroteskUrl from "../fonts/CabinetGrotesk-Variable.woff2?url";

type Props = {
  canonicalPath?: string;
  description?: string;
  imagePreloads?: {
    href: string;
    imagesizes: string;
    imagesrcset: string;
    media?: string;
    type: string;
  }[];
  title?: string;
};

const {
  canonicalPath = "/",
  description = siteConfig.description,
  imagePreloads = [],
  title = siteConfig.title,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, siteConfig.url).toString();
const pageTitle = title === siteConfig.title ? siteConfig.title : `${title} | ${siteConfig.name}`;
const criticalFontCss = `
@font-face {
  font-family: "Cabinet Grotesk";
  src: url("${cabinetGroteskUrl}") format("woff2");
  font-weight: 100 900;
  font-style: normal;
  font-display: block;
}
html,
body {
  font-family: "Cabinet Grotesk", Arial, Helvetica, sans-serif;
}
html.fonts-pending body {
  opacity: 0;
}
html.fonts-ready body,
html.no-font-loading body {
  opacity: 1;
}
`;
---

<!doctype html>
<html lang="en" data-scroll-behavior="smooth" class="fonts-pending">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content={siteConfig.name} />
    <meta name="theme-color" content="#ffffff" />
    <meta name="referrer" content="origin-when-cross-origin" />
    <meta name="keywords" content={siteConfig.keywords.join(", ")} />
    <meta name="author" content={siteConfig.author} />
    <meta name="creator" content={siteConfig.author} />
    <meta name="publisher" content={siteConfig.author} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preload" href={cabinetGroteskUrl} as="font" type="font/woff2" crossorigin />
    {imagePreloads.map((image) => (
      <link rel="preload" as="image" href={image.href} imagesrcset={image.imagesrcset} imagesizes={image.imagesizes} type={image.type} fetchpriority="high" media={image.media} />
    ))}
    <style is:inline set:html={criticalFontCss}></style>
    <link rel="icon" href="/static/favicon.svg" />
    <link rel="shortcut icon" href="/static/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:image" content={new URL(defaultOpenGraphImage.url, siteConfig.url).toString()} />
    <meta property="og:image:width" content={String(defaultOpenGraphImage.width)} />
    <meta property="og:image:height" content={String(defaultOpenGraphImage.height)} />
    <meta property="og:image:alt" content={defaultOpenGraphImage.alt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(defaultTwitterImage, siteConfig.url).toString()} />
    <meta name="format-detection" content="address=no,email=no,telephone=no" />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        if (!("fonts" in document)) {
          root.classList.remove("fonts-pending");
          root.classList.add("no-font-loading");
          return;
        }
        document.fonts.load('1em "Cabinet Grotesk"').then(() => {
          root.classList.remove("fonts-pending");
          root.classList.add("fonts-ready");
        });
      })();
    </script>
    <script is:inline>
      (() => {
        const storageKey = "theme";
        const root = document.documentElement;
        const themeColors = {
          light: "#ffffff",
          dark: "#000000",
        };
        const syncThemeColorMeta = (color) => {
          document.querySelectorAll('meta[name="theme-color"]').forEach((meta) => meta.remove());
          const themeColorMeta = document.createElement("meta");
          themeColorMeta.name = "theme-color";
          themeColorMeta.content = color;
          document.head.append(themeColorMeta);
        };
        const setTheme = (theme, options = {}) => {
          const normalizedTheme = theme === "dark" ? "dark" : "light";
          const themeColor = themeColors[normalizedTheme];
          root.classList.toggle("dark", normalizedTheme === "dark");
          root.style.colorScheme = normalizedTheme;
          root.style.backgroundColor = themeColor;
          if (document.body) {
            document.body.style.backgroundColor = themeColor;
            document.body.style.colorScheme = normalizedTheme;
          }
          syncThemeColorMeta(themeColor);
          root.dataset.theme = normalizedTheme;
          root.dataset.themePaint = String(Date.now());
          if (options.persist) {
            localStorage.setItem(storageKey, normalizedTheme);
          }
          requestAnimationFrame(() => {
            root.dataset.themePaint = "";
          });
        };
        const storedTheme = localStorage.getItem(storageKey);
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = storedTheme || (prefersDark ? "dark" : "light");
        setTheme(theme);
        window.__setSiteTheme = setTheme;
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", () => {
            setTheme(root.dataset.theme || theme);
          }, { once: true });
        }
      })();
    </script>
    <script is:inline>
      (() => {
        if (!("serviceWorker" in navigator)) return;
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        }, { once: true });
      })();
    </script>
  </head>
  <body class="antialiased bg-white dark:bg-black">
    <slot />
  </body>
</html>
